# Neogild — local development
# Copy to apps/web/.env.local after `npm run db:start`

NEXT_PUBLIC_SUPABASE_URL=http://127.0.0.1:54321
NEXT_PUBLIC_SUPABASE_ANON_KEY=<from supabase start output>
SUPABASE_SERVICE_ROLE_KEY=<from supabase start output>

# LLM (Phase 2+)
# LLM_PROVIDER=gemini
# GOOGLE_GENERATIVE_AI_API_KEY=

# Email ingestion — IMAP + App Password (ADR-012)
GMAIL_USER=
GMAIL_APP_PASSWORD=
# Optional: skip Settings UI during dev (CLI sync only)
# GMAIL_IMAP_HOST=imap.gmail.com
